RewriteEngine On

# Keep crawler files as real files, without HTML fallback.
AddType application/xml .xml
RewriteRule ^(sitemap\.xml|robots\.txt)$ - [L]

# Redireciona index.html para a raiz
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^index\.html$ /  [R=301,L]

# Redireciona qualquer-pagina.html para qualquer-pagina sem extensao
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internamente, serve o .html quando a URL nao tem extensao
RewriteRule ^listadepresenca/?$ lista\ de\ presenca.html [L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^.]+)$ $1.html [L]
